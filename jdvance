#!/bin/bash
# jdvance CLI — lightweight commands for the jdvance system
# Usage: jdvance dashboard

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

case "${1:-}" in
  dashboard)
    # Determine which knowledge file to use
    # Priority: project level, then root level
    if [ -f ".jdvance/knowledge.json" ]; then
      KNOWLEDGE_FILE=".jdvance/knowledge.json"
      echo "Loading project knowledge from .jdvance/knowledge.json"
    elif [ -f "$HOME/.jdvance/knowledge.json" ]; then
      KNOWLEDGE_FILE="$HOME/.jdvance/knowledge.json"
      echo "Loading root knowledge from ~/.jdvance/knowledge.json"
    else
      echo "No knowledge.json found."
      echo "  Project: .jdvance/knowledge.json"
      echo "  Root:    ~/.jdvance/knowledge.json"
      exit 1
    fi

    # Read knowledge data
    KNOWLEDGE_DATA=$(cat "$KNOWLEDGE_FILE")

    # Find the dashboard HTML template
    # Check common locations
    if [ -f "$SCRIPT_DIR/dashboard.html" ]; then
      TEMPLATE="$SCRIPT_DIR/dashboard.html"
    elif [ -f "$HOME/.jdvance/dashboard.html" ]; then
      TEMPLATE="$HOME/.jdvance/dashboard.html"
    else
      echo "dashboard.html not found. Downloading..."
      curl -sL https://raw.githubusercontent.com/MikWess/jdvance/main/dashboard.html -o /tmp/jdvance-dashboard-template.html
      TEMPLATE="/tmp/jdvance-dashboard-template.html"
    fi

    # Inject data into HTML and write to temp file
    TMPFILE=$(mktemp /tmp/jdvance-dashboard-XXXXXX.html)

    # Insert the data script right before the closing </head> tag
    DATA_SCRIPT="<script>var __KNOWLEDGE_DATA__ = $KNOWLEDGE_DATA;</script>"
    sed "s|</head>|$DATA_SCRIPT</head>|" "$TEMPLATE" > "$TMPFILE"

    echo "Opening dashboard..."
    open "$TMPFILE" 2>/dev/null || xdg-open "$TMPFILE" 2>/dev/null || echo "Open $TMPFILE in your browser"
    ;;

  *)
    echo "jdvance — your senior dev in the terminal"
    echo ""
    echo "Commands:"
    echo "  dashboard    Open the knowledge dashboard in your browser"
    echo ""
    echo "To install into a project:"
    echo "  curl -sL https://raw.githubusercontent.com/MikWess/jdvance/main/install.sh | bash"
    ;;
esac
